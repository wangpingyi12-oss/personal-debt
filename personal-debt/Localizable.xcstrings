    "error.billingDateAfterDueDate" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Billing date must not be later than due date."}},"zh-Hans":{"stringUnit":{"state":"translated","value":"账单日不能晚于还款日。"}}}},
    "error.manualOverdueBeforeDueDate" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Manual overdue start date must not be earlier than the statement due date."}},"zh-Hans":{"stringUnit":{"state":"translated","value":"手动逾期开始日期不能早于账单还款日。"}}}},

