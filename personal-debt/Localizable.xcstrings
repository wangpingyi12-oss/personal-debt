    "error.overdueStartBeforeDueDate" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Overdue start date must not be earlier than the due date."}},"zh-Hans":{"stringUnit":{"state":"translated","value":"逾期开始日期不能早于还款日。"}}}},
    "error.overdueStartInFuture" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Overdue start date must not be later than today."}},"zh-Hans":{"stringUnit":{"state":"translated","value":"逾期开始日期不能晚于今天。"}}}},
    "error.onlyUserOverdueCanBeEdited" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Only user-managed overdue records can be edited."}},"zh-Hans":{"stringUnit":{"state":"translated","value":"只能编辑用户管理的逾期记录。"}}}},
