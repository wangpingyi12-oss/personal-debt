    "app.disclaimer" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This app helps organize debts and repayment plans. It is not a financial institution and does not replace creditor records."
