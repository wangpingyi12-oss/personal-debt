    "subscription.terms.autoRenew" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"The subscription renews automatically unless cancelled at least 24 hours before the end of the current period."}},"zh-Hans":{"stringUnit":{"state":"translated","value":"订阅会自动续期，除非在当前周期结束前至少 24 小时取消。"}}}},
